    "logo_url": "",
    "logo_width": 250,
    "logo_height": 150,
    "logo_radius": 20,
    "logo_padding": 10,
    "logo_fit": "contain"
  },
  "theme": {
    "accent": "#2f6fed",
    "hero_text": "#ffffff",
    "chrome_start": "#145aa0",
